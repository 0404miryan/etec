# Contadores
excelente = 0
ruim = 0

# Loop para 50 entrevistados
for i in range(50):
    print(f"\nEntrevistado {i+1}")

    nome = input("Digite o nome: ")
    idade = int(input("Digite a idade: "))

    print("Opinião sobre o atendimento:")
    print("1 - EXCELENTE")
