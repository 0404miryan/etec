from colorama import Fore, Style, init
init(autoreset=True)
import random


niveis = [
    "Nível 1 - Muito baixo (crítico): Aumente o nível de água urgentemente",
    "Nível 2 - Baixo: Aumente o nível de água ",
    "Nível 3 - Médio: mantenha o nível de água estavel",
    "Nível 4 - Alto: Diminua o nível de água ",
    "Nível 5 - Muito alto (alerta): Retire água urgentemente",
]

def definir_cor(nivel):
    if nivel == 1:
        return Fore.RED
    elif nivel == 2:
        return Fore.YELLOW
    elif nivel == 3:
        return Fore.GREEN
    elif nivel == 4:
        return Fore.CYAN
    elif nivel == 5:
        return Fore.BLUE
    else:
        return Fore.WHITE

nivel = random.randint(1,5)
cor = definir_cor(nivel)
print(cor + niveis[nivel - 1])

print(Style.RESET_ALL)
